{
  "manifest_version": 3,
  "name": "Skrutable Sanskrit Tools",
  "version": "1.0.0",
  "description": "Sanskrit transliteration, scansion, meter identification, and splitting for selected text on any webpage.",
  "host_permissions": [
    "https://dharmamitra.org/*",
    "https://2018emnlp-sanskrit-splitter-server.duckdns.org/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Skrutable Sanskrit Tools"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "options_page": "ui/options.html",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  }
}
