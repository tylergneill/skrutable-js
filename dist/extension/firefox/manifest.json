{
  "manifest_version": 3,
  "name": "Skrutable Sanskrit Tools",
  "version": "1.0.0",
  "description": "Sanskrit transliteration, scansion, meter identification, and splitting for selected text on any webpage.",
  "host_permissions": [
    "https://dharmamitra.org/*",
    "https://2018emnlp-sanskrit-splitter-server.duckdns.org/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Skrutable Sanskrit Tools"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "options_page": "ui/options.html",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "menus"
  ],
  "background": {
    "scripts": [
      "js/background.js"
    ],
    "type": "module"
  },
  "sidebar_action": {
    "default_panel": "ui/sidepanel.html",
    "default_title": "Skrutable Sanskrit Tools",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "96": "assets/icon96.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "skrutable@tylergneill.com",
      "strict_min_version": "126.0"
    }
  }
}
