{
  "name": "skrutable-js",
  "version": "2.1.2",
  "description": "JavaScript toolkit for Sanskrit text transliteration, scansion, and meter identification",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "build:extension:chrome": "node extension/build.cjs chrome",
    "build:extension:firefox": "node extension/build.cjs firefox"
  },
  "keywords": [
    "sanskrit",
    "transliteration",
    "scansion",
    "meter",
    "identification",
    "devanagari",
    "iast",
    "prosody"
  ],
  "author": "Antariksh Bothale",
  "contributors": [
    "Tyler Neill <tyler.g.neill@gmail.com> (https://www.npmjs.com/~tylergneill)"
  ],
  "license": "CC-BY-SA-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/linguistrix/skrutable-js"
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "jest": "^29.7.0",
    "rollup": "^4.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^.+scheme_vectors\\.json$": "<rootDir>/src/scheme_vectors.json",
      "^.+impossible_bigrams\\.json$": "<rootDir>/src/impossible_bigrams.json"
    }

  }
}
